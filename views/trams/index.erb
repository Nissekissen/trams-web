<div class="page-header">
  <div>
    <div class="eyebrow">Spårvagnar</div>
    <h1>Utforska</h1>
  </div>
</div>

<% @models.each do |model| %>
  <% next if model.trams.empty? %>
  <% trams = model.trams.sort_by(&:number) %>
  <% ridden = trams.count { |t| @ridden_tram_ids.include?(t.id) } %>
  <% percent = (ridden.to_f / trams.size * 100).round %>

  <div class="model-section">
    <div class="model-banner <%= 'model-banner--complete' if ridden == trams.size %>">
      <span class="model-banner-name"><%= h(model.name) %></span>
      <span class="model-banner-count"><%= ridden %>/<%= trams.size %> åkta</span>
    </div>
    <div class="model-progress-bar">
      <div class="model-progress-fill" style="width: <%= percent %>%;"></div>
    </div>
    <div class="tram-list">
      <% trams.each do |tram| %>
        <% ridden_tram = @ridden_tram_ids.include?(tram.id) %>
        <% lines = @lines_by_tram[tram.id] || [] %>
        <% has_detail = tram.description.present? || lines.any? %>
        <div class="tram-row <%= 'tram-row--ridden' if ridden_tram %>" data-tram-id="<%= tram.id %>">
          <div class="tram-row-summary" <%= 'onclick="toggleTram(this)"' if has_detail %>>
            <span class="tram-row-num"><%= h(tram.number) %></span>
            <span class="tram-row-name"><%= h(tram.name) if tram.name.present? %></span>
            <div class="tram-row-check <%= 'tram-row-check--done' if ridden_tram %>"><% if ridden_tram %>✓<% end %></div>
            <% if has_detail %>
              <i class="ti ti-chevron-down tram-row-chevron" aria-hidden="true"></i>
            <% end %>
          </div>
          <% if has_detail %>
            <div class="tram-row-detail">
              <% if tram.description.present? %>
                <p class="tram-row-desc"><%= h(tram.description) %></p>
              <% end %>
              <% if lines.any? %>
                <div class="tram-row-detail-label">Sedd på linjer</div>
                <div class="line-pills">
                  <% lines.each do |line| %>
                    <% colors = Ride.color_for(line) %>
                    <div class="line-pill line-pill-sm" style="background:<%= colors[:bg] %>; color:<%= colors[:text] %>; border: 1.5px solid #1a1a1a; box-shadow: 0 1.5px 0 #1a1a1a;">
                      <%= line %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<script>
function toggleTram(summary) {
  summary.closest('.tram-row').classList.toggle('tram-row--expanded');
}
</script>
