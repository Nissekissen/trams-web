<div class="page-header">
  <div>
    <div class="eyebrow">Spårvagnar</div>
    <h1>Utforska</h1>
  </div>
</div>

<% @models.each do |model| %>
  <% next if model.trams.empty? %>
  <% ridden = model.trams.count { |t| @ridden_tram_ids.include?(t.id) } %>

  <div class="model-section">
    <div class="model-section-header">
      <h2><%= h(model.name) %></h2>
      <span class="muted"><%= ridden %>/<%= model.trams.size %> åkta</span>
    </div>

    <% if model.description.present? %>
      <p class="model-description muted"><%= h(model.description) %></p>
    <% end %>

    <div class="tram-grid">
      <% model.trams.sort_by(&:number).each do |tram| %>
        <% ridden = @ridden_tram_ids.include?(tram.id) %>
        <a href="/trams/<%= tram.id %>" class="tram-card <%= 'tram-card--ridden' if ridden %>">
          <div class="tram-card-number"><%= h(tram.number) %></div>
          <% if tram.name.present? %>
            <div class="tram-card-name"><%= h(tram.name) %></div>
          <% end %>
          <% if ridden %>
            <div class="tram-card-ridden">✓</div>
          <% end %>
        </a>
      <% end %>
    </div>
  </div>
<% end %>
