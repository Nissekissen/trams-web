<div class="page-header">
  <div>
    <div class="eyebrow">Spårvagnar</div>
    <h1>Alla spårvagnar</h1>
  </div>
  <div class="form-actions" style="margin-top:0;">
    <a href="/admin/trams/new" class="btn">+ Lägg till spårvagn</a>
    <a href="/models/new" class="btn btn-secondary">+ Ny modell</a>
  </div>
</div>

<% if @models.any? %>
  <form method="get" action="/admin/trams" class="model-filter">
    <input type="hidden" name="filtered" value="1">
    <% @models.each do |model| %>
      <label class="model-filter-pill">
        <input type="checkbox" name="model_ids[]" value="<%= model.id %>"
               <%= 'checked' if @selected_model_ids.include?(model.id) %>
               onchange="this.form.submit()">
        <%= h(model.name) %>
      </label>
    <% end %>
  </form>
<% end %>

<% if @trams_by_model.empty? %>
  <div class="empty-state">
    <p>Inga spårvagnar att visa.</p>
    <a href="/admin/trams/new">Lägg till din första spårvagn →</a>
  </div>
<% else %>
  <% @models.each do |model| %>
    <% trams = @trams_by_model[model] %>
    <% next unless trams %>
    <div class="course-block">
      <h3><%= h(model.name) %></h3>
      <div class="card-list">
        <% trams.each do |tram| %>
          <div class="card row-link">
            <div>
              <h3>
                <%= h(tram.number) %>
                <% if tram.name.present? %><span class="muted">· <%= h(tram.name) %></span><% end %>
              </h3>
              <% if tram.description.present? %><p class="muted"><%= h(tram.description) %></p><% end %>
            </div>
            <div class="form-actions" style="margin-top:0;">
              <a href="/admin/trams/<%= tram.id %>/edit" class="btn btn-secondary btn-sm">Redigera</a>
              <form method="post" action="/trams/<%= tram.id %>" class="inline"
                    onsubmit="return confirm('Ta bort spårvagn <%= h(tram.number) %>? Detta går inte att ångra.');">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn btn-danger btn-sm">Ta bort</button>
              </form>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
