<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Trams</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
  <div class="layout">
    <header class="topbar">
      <div class="brand">Trams<span class="dot">.</span></div>
      <nav>
        <a href="/">Hem</a>
        <a href="/trams">Spårvagnar</a>
      </nav>
    </header>

    <aside class="sidebar">
      <div class="brand">Trams<span class="dot">.</span></div>
      <ul class="nav-list">
        <li><a href="/" class="<%= 'active' if nav_active?('/') %>">Hem</a></li>
        <li><a href="/trams" class="<%= 'active' if nav_active?('/trams') %>">Spårvagnar</a></li>
      </ul>
      <form method="post" action="/logout" style="margin-top: auto;">
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" class="btn btn-secondary" style="width: 100%;">Logga ut</button>
      </form>
    </aside>

    <main class="content">
      <%= yield %>
    </main>
  </div>
</body>
</html>
