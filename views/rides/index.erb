<div class="page-header">
  <div>
    <div class="eyebrow">Resor</div>
    <h1>Alla resor</h1>
  </div>
  <a href="/" class="btn btn-secondary">+ Ny resa</a>
</div>

<form method="get" action="/rides" class="card" style="margin-bottom:1.75rem;">
  <label for="user_id">Användare</label>
  <select id="user_id" name="user_id" onchange="this.form.submit()" required>
    <option value="">Välj användare</option>
    <% @users.each do |user| %>
      <option value="<%= user.id %>" <%= 'selected' if @selected_user_id == user.id %>>
        <%= h(user.name) %>
      </option>
    <% end %>
  </select>
</form>

<% if @selected_user_id.nil? %>
  <div class="empty-state">
    <p>Välj en användare ovan för att se deras resor.</p>
  </div>
<% elsif @rides.empty? %>
  <div class="empty-state">
    <p>Inga resor loggade än.</p>
    <a href="/">Logga den första resan →</a>
  </div>
<% else %>
  <div class="card">
    <% @rides.each do |ride| %>
      <div class="log-entry">
        <div class="log-marker"><%= ride.ridden_on %></div>
        <div class="log-body">
          <h3>
            <%= h(ride.tram.number) %><% if ride.tram.name.present? %> · <%= h(ride.tram.name) %><% end %>
            <span class="badge badge-muted"><%= h(ride.tram.model.name) %></span>
          </h3>
          <% color = Ride.color_for(ride.line) %>
          <div class="line-pill line-pill-sm" style="background: <%= color[:bg] %>; color: <%= color[:text] %>;">
            <%= ride.line %>
          </div>
        </div>
        <form method="post" action="/rides/<%= ride.id %>" class="inline"
              onsubmit="return confirm('Ta bort den här resan? Detta går inte att ångra.');">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn btn-danger btn-sm">Ta bort</button>
        </form>
      </div>
    <% end %>
  </div>
<% end %>
