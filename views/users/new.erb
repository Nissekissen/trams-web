<div class="page-header">
  <div>
    <div class="eyebrow">Användare</div>
    <h1>Ny användare</h1>
  </div>
</div>

<div class="card">
  <form method="post" action="/users">
    <label for="name">Namn</label>
    <input type="text" id="name" name="name" value="<%= h(@user.name) %>" required autofocus>

    <div class="form-actions">
      <button type="submit" class="btn">Spara användare</button>
      <a href="/" class="btn btn-secondary">Avbryt</a>
    </div>
  </form>
</div>
