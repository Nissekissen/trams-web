<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Logga in · Trams</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= File.mtime(File.join(settings.public_folder, 'css', 'style.css')).to_i %>">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body class="auth-page">
  <div class="auth-wrap">

    <div class="auth-brand">
      Trams
      <span class="auth-brand-sub">Spåra dina resor</span>
    </div>

    <div class="auth-card">
      <% if @error %>
        <div class="form-error" style="margin-bottom: 0.25rem;"><%= h(@error) %></div>
      <% end %>

      <form method="post" action="/login" class="profile-form">
        <label for="email">E-post</label>
        <input type="email" id="email" name="email" value="<%= h(params['email']) %>" required autofocus autocomplete="email" placeholder="din@email.com">

        <label for="password">Lösenord</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••">

        <button type="submit" class="btn-game btn-game--primary" style="margin-top: 0.35rem; width: 100%;">Logga in</button>
      </form>
    </div>

    <p class="auth-footer">Inget konto? <a href="/signup">Kom igång</a></p>

  </div>
</body>
</html>
