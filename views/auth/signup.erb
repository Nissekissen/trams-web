<div style="max-width: 400px;">

<div class="page-header">
  <div>
    <div class="eyebrow">Konto</div>
    <h1>Skapa konto</h1>
  </div>
</div>

<% if @user.errors.any? %>
  <div class="note" style="border-color: #8a3a3a; margin-bottom: 1.25rem;">
    <% @user.errors.full_messages.each do |msg| %>
      <div><%= h(msg) %></div>
    <% end %>
  </div>
<% end %>

<div class="card">
  <form method="post" action="/signup">
    <label for="name">Namn</label>
    <input type="text" id="name" name="name" value="<%= h(@user.name) %>" required autofocus>

    <label for="email">E-post</label>
    <input type="email" id="email" name="email" value="<%= h(@user.email) %>" required>

    <label for="password">Lösenord</label>
    <input type="password" id="password" name="password" required>

    <label for="password_confirmation">Bekräfta lösenord</label>
    <input type="password" id="password_confirmation" name="password_confirmation" required>

    <div class="form-actions">
      <button type="submit" class="btn">Skapa konto</button>
    </div>
  </form>
</div>

<p style="margin-top: 1rem; font-size: 0.88rem; color: var(--color-muted);">
  Har du redan ett konto? <a href="/login">Logga in här</a>.
</p>

</div>
