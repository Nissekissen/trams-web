<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Skapa konto · Trams</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= File.mtime(File.join(settings.public_folder, 'css', 'style.css')).to_i %>">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body class="auth-page">
  <div class="auth-wrap">

    <div class="auth-brand">
      Trams
      <span class="auth-brand-sub">Kom igång</span>
    </div>

    <div class="auth-card">
      <% if @error %>
        <div class="form-error"><%= h(@error) %></div>
      <% end %>

      <form method="post" action="/signup/start" class="profile-form">
        <label for="email">E-post</label>
        <input type="email" id="email" name="email" value="<%= h(@email) %>" required autofocus autocomplete="email" placeholder="din@email.com">

        <button type="submit" class="btn-game btn-game--primary" style="margin-top: 0.35rem; width: 100%;">Nästa</button>
      </form>
    </div>

    <p class="auth-footer">Har du redan ett konto? <a href="/login">Logga in</a></p>

  </div>
</body>
</html>
