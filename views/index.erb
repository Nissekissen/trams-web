<div class="page-header">
  <div>
    <div class="eyebrow">Hem</div>
    <h1>Trams</h1>
  </div>
</div>

<div class="hero-stat card">
  <div class="hero-stat-value"><%= @week_ride_count %></div>
  <div class="hero-stat-label">resor den här veckan</div>
</div>

<div class="stats-row">
  <div class="stat-chip">
    <div class="stat-chip-value"><%= @ride_count %></div>
    <div class="stat-chip-label">Resor totalt</div>
  </div>
  <div class="stat-chip">
    <div class="stat-chip-value"><%= @ridden_tram_ids.size %>/<%= @total_trams %></div>
    <div class="stat-chip-label">Spårvagnar</div>
  </div>
  <div class="stat-chip">
    <div class="stat-chip-value"><%= @ridden_lines.size %>/<%= Ride::LINES.size %></div>
    <div class="stat-chip-label">Linjer</div>
  </div>
</div>

<% if @recent_rides.any? %>
  <div class="section-label">Senaste resor</div>
  <div class="recent-rides">
    <% @recent_rides.each do |ride| %>
      <% colors = Ride.color_for(ride.line) %>
      <div class="recent-ride-row">
        <div class="recent-ride-line-pill" style="background:<%= colors[:bg] %>; color:<%= colors[:text] %>;"><%= ride.line %></div>
        <div class="recent-ride-info">
          <span class="recent-ride-num"><%= h(ride.tram.number) %></span>
          <span class="recent-ride-model"><%= h(ride.tram.model.name) %></span>
        </div>
        <div class="recent-ride-left-box">
        <form method="post" action="/rides/<%= ride.id %>" class="inline delete-ride-btn-wrapper"
              onsubmit="return confirm('Ta bort resan? Detta går inte att ångra.');">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn btn-danger btn-sm">Ta bort</button>
        </form>
        <div class="recent-ride-date"><%= ride.ridden_on.strftime('%-d %b') %></div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
